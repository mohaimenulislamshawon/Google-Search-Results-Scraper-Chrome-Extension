{
  "manifest_version": 3,
  "name": "Google Search Results Scraper",
  "version": "1.0.0",
  "description": "Automatically scrapes all Google search result pages by clicking Next until no more pages exist",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*", "https://google.com/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
